            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Read",
          "description": "Read files.",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Grep",
          "description": "Search files.",
          "parameters": {
            "type": "object"
          }
        }
      }
    ],
    "model_text": "Review summary: use the earlier Glob result and focus on the listed Python files."
  },
  "expected": {
    "error": null,
