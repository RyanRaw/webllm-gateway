{
  "id": "package_requirement_text_as_bash",
  "description": "ds2api-style all profile passes declared Bash dependency-looking text through as a tool call.",
  "protocol": "anthropic_messages",
  "model": "qwen-coder/qwen-coder-plus",
  "tool_bridge_config": {
    "mode": "strict",
    "activationPolicy": "auto",
    "exposurePolicy": "all",
    "toolProfile": "all",
    "maxCallsPerTurn": 4
  },
  "input": {
    "task_text": "Implement the improvement plan in this local codebase.",
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "Bash",
          "description": "Run shell commands.",
          "parameters": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              }
            },
            "required": [
              "command"
            ]
          }
        }
      }
    ],
    "model_text": "```tool_json\n{\"calls\":[{\"id\":\"call_1\",\"name\":\"Bash\",\"input\":{\"command\":\"python-dotenv>=1.0.0 && pytest>=7.0.0 && pytest-asyncio>=0.21.0\"}}]}\n```"
  },
  "expected": {
    "error": null,
    "tool_calls": [
      {
        "id": "call_1",
        "name": "Bash",
        "input": {
          "command": "python-dotenv>=1.0.0 && pytest>=7.0.0 && pytest-asyncio>=0.21.0"
        }
      }
    ],
    "warning_contains": null
  }
}
