{
  "id": "anthropic_controller_repair_then_tool_call",
  "description": "Anthropic controller returns the first declared Bash call unchanged in ds2api-style all profile.",
  "protocol": "anthropic_messages",
  "tool_bridge_config": {
    "mode": "strict",
    "activationPolicy": "auto",
    "exposurePolicy": "all",
    "toolProfile": "all"
  },
  "request": {
    "model": "web-model",
    "messages": [
      {
        "role": "user",
        "content": "Implement the local project improvement plan."
      }
    ],
    "tools": [
      {
        "name": "Bash",
        "input_schema": {
          "type": "object"
        }
      },
      {
        "name": "Read",
        "description": "Read a file",
        "input_schema": {
          "type": "object"
        }
      }
    ],
    "max_tokens": 1024
  },
  "upstream": {
    "contents": [
      "```tool_json\n{\"calls\":[{\"id\":\"call_bad\",\"name\":\"Bash\",\"input\":{\"command\":\"python-dotenv>=1.0.0 && pytest>=7.0.0\"}}]}\n```",
      "```tool_json\n{\"calls\":[{\"id\":\"toolu_read\",\"name\":\"Read\",\"input\":{\"file_path\":\"README.md\"}}]}\n```"
    ]
  },
  "expected": {
    "status": 200,
    "upstreamCalls": 1,
    "upstreamOmits": [
      "tools",
      "tool_choice"
    ],
    "stopReason": "tool_use",
    "toolCall": {
      "name": "Bash",
      "input": {
        "command": "python-dotenv>=1.0.0 && pytest>=7.0.0"
      }
    }
  }
}
