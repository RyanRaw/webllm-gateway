{
  "id": "openai_controller_blocks_unapproved_shell",
  "description": "OpenAI clients receive declared Bash calls unchanged in ds2api-style all profile.",
  "protocol": "openai_chat_completions",
  "tool_bridge_config": {
    "mode": "strict",
    "activationPolicy": "auto",
    "exposurePolicy": "all",
    "toolProfile": "all"
  },
  "request": {
    "model": "web-model",
    "messages": [
      {
        "role": "user",
        "content": "Implement the local project improvement plan."
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "AskUserQuestion",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Bash",
          "description": "Run shell commands",
          "parameters": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              }
            }
          }
        }
      }
    ]
  },
  "upstream": {
    "content": "```tool_json\n{\"calls\":[{\"id\":\"call_1\",\"name\":\"Bash\",\"input\":{\"command\":\"pip install -r requirements.txt\"}}]}\n```"
  },
  "expected": {
    "status": 200,
    "upstreamCalls": 1,
    "upstreamOmits": [
      "tools",
      "tool_choice"
    ],
    "finishReason": "tool_calls",
    "toolCall": {
      "name": "Bash",
      "input": {
        "command": "pip install -r requirements.txt"
      }
    }
  }
}
