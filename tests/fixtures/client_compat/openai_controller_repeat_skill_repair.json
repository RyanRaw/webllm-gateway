{
  "id": "openai_controller_repeat_skill_repair",
  "description": "OpenAI controller rejects repeated Skill calls and retries until the model uses a different allowed tool.",
  "protocol": "openai_chat_completions",
  "tool_bridge_config": {
    "mode": "strict",
    "activationPolicy": "auto",
    "exposurePolicy": "all",
    "toolProfile": "agent"
  },
  "request": {
    "model": "web-model",
    "messages": [
      {
        "role": "user",
        "content": "Review local project code and make an improvement plan."
      },
      {
        "role": "assistant",
        "content": "",
        "tool_calls": [
          {
            "id": "call_skill",
            "type": "function",
            "function": {
              "name": "Skill",
              "arguments": "{\"skill\":\"using-superpowers\"}"
            }
          }
        ]
      },
      {
        "role": "tool",
        "tool_call_id": "call_skill",
        "content": "Launching skill: using-superpowers"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "Skill",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Read",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Glob",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Grep",
          "parameters": {
            "type": "object"
          }
        }
      }
    ]
  },
  "upstream": {
    "contents": [
      "```tool_json\n{\"calls\":[{\"id\":\"call_skill_again\",\"name\":\"Skill\",\"input\":{\"skill\":\"using-superpowers\"}}]}\n```",
      "```tool_json\n{\"calls\":[{\"id\":\"call_read\",\"name\":\"Read\",\"input\":{\"file_path\":\"README.md\"}}]}\n```"
    ]
  },
  "expected": {
    "status": 200,
    "upstreamCalls": 2,
    "upstreamOmits": [
      "tools",
      "tool_choice"
    ],
    "upstreamMessageContains": "Do not request the same Skill again",
    "finishReason": "tool_calls",
    "toolCall": {
      "name": "Read",
      "input": {
        "file_path": "README.md"
      }
    }
  }
}
