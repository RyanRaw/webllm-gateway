{
  "id": "openai_controller_mixed_repeat_discovery_batch",
  "description": "OpenAI controller drops repeated discovery calls from a mixed batch while preserving a valid progress call.",
  "protocol": "openai_chat_completions",
  "tool_bridge_config": {
    "mode": "strict",
    "activationPolicy": "auto",
    "exposurePolicy": "all",
    "toolProfile": "agent"
  },
  "request": {
    "model": "web-model",
    "messages": [
      {
        "role": "user",
        "content": "/using-superpowers implement the local codebase plan"
      },
      {
        "role": "assistant",
        "content": "",
        "tool_calls": [
          {
            "id": "call_glob_old",
            "type": "function",
            "function": {
              "name": "Glob",
              "arguments": "{\"path\":\"E:/ProjectX/mindcraft\",\"pattern\":\"**/*.py\"}"
            }
          }
        ]
      },
      {
        "role": "tool",
        "tool_call_id": "call_glob_old",
        "content": "rewrite_content.py\nsync_to_feishu.py"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "Read",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Glob",
          "parameters": {
            "type": "object"
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "Grep",
          "parameters": {
            "type": "object"
          }
        }
      }
    ]
  },
  "upstream": {
    "content": "```tool_json\n{\"calls\":[{\"id\":\"call_repeat\",\"name\":\"Glob\",\"input\":{\"path\":\"E:/ProjectX/mindcraft\",\"pattern\":\"**/*.py\"}},{\"id\":\"call_read\",\"name\":\"Read\",\"input\":{\"file_path\":\"E:/ProjectX/mindcraft/sync_to_feishu.py\"}}]}\n```"
  },
  "expected": {
    "status": 200,
    "upstreamCalls": 1,
    "upstreamOmits": [
      "tools",
      "tool_choice"
    ],
    "finishReason": "tool_calls",
    "toolCall": {
      "name": "Read",
      "input": {
        "file_path": "E:/ProjectX/mindcraft/sync_to_feishu.py"
      }
    }
  }
}
