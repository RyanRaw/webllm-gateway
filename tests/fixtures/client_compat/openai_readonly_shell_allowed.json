{
  "id": "openai_readonly_shell_allowed",
  "description": "OpenAI review clients may receive read-only shell tool calls.",
  "protocol": "openai_chat_completions",
  "tool_bridge_config": {
    "mode": "strict",
    "activationPolicy": "auto",
    "exposurePolicy": "all",
    "toolProfile": "all",
    "maxCallsPerTurn": 4
  },
  "request": {
    "model": "web-model",
    "messages": [
      {
        "role": "user",
        "content": "Review this codebase and suggest improvements."
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "Bash",
          "description": "Run shell commands",
          "parameters": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              }
            },
            "required": [
              "command"
            ]
          }
        }
      }
    ]
  },
  "upstream": {
    "content": "```tool_json\n{\"calls\":[{\"id\":\"call_1\",\"name\":\"Bash\",\"input\":{\"command\":\"git status --short\"}}]}\n```"
  },
  "expected": {
    "status": 200,
    "upstreamCalls": 1,
    "upstreamOmits": [
      "tools",
      "tool_choice"
    ],
    "finishReason": "tool_calls",
    "toolCall": {
      "name": "Bash",
      "input": {
        "command": "git status --short"
      }
    }
  }
}
