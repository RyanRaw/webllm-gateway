{
  "server": {
    "host": "127.0.0.1",
    "port": 8610,
    "apiKey": "local-dev-key"
  },
  "upstream": {
    "baseUrl": "http://127.0.0.1:8500/v1",
    "apiKey": "",
    "model": "webai2api-model",
    "toolMode": "prompt"
  },
  "providerRuntime": {
    "requestTimeoutSeconds": 300,
    "promptMaxChars": 32000,
    "nativeWebSearchPolicy": "auto",
    "responseLanguage": "zh-CN",
    "deepseekDs2apiBaseUrl": "http://127.0.0.1:9331/v1"
  },
  "tool_bridge": {
    "mode": "strict",
    "activationPolicy": "auto",
    "maxToolsInPrompt": 32,
    "maxCallsPerTurn": 4,
    "maxReadonlyCallsPerTurn": 32,
    "toolPromptMaxChars": 8000,
    "observationMaxChars": 4000,
    "exposurePolicy": "all",
    "toolProfile": "all",
    "semanticFinalJudge": "off",
    "allowedToolNames": [],
    "readonlyToolNames": [
      "Read",
      "Glob",
      "Grep"
    ],
    "writeToolNames": [
      "Edit",
      "Write"
    ],
    "shellToolNames": [
      "Bash"
    ],
    "observationPolicy": {
      "summarizePathLists": true,
      "excludedPathParts": [
        ".cache",
        ".git",
        ".hg",
        ".mypy_cache",
        ".next",
        ".nuxt",
        ".pnpm",
        ".pytest_cache",
        ".ruff_cache",
        ".svn",
        ".turbo",
        ".venv",
        "__pycache__",
        "bower_components",
        "build",
        "coverage",
        "dist",
        "node_modules",
        "site-packages",
        "target",
        "vendor"
      ],
      "excludedPathGlobs": [],
      "pathListMaxItems": 80
    }
  }
}
